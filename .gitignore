# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment variables and sensitive data
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.idea/
.claude/
.spec-workflow/

# foundry
# Compiler files
cache/
out/
contracts/bin

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# deployment files - contains addresses that vary by environment
contracts/deployments/

# log files
*.log
.next/**/logs/

# keystore files and private keys
*.keystore
**/keystore/
**/wallets/
*.key
*.secret
*.private
*.p12
*.pfx
**/private/**
**/keys/**

# API keys and credentials
*.cer
*.crt
*.cert
config/

# Additional privacy files
**/credentials
**/secrets
**/passwords
**/access_tokens
**/refresh_tokens
**/oauth_tokens
**/jwks.json
**/signatures.json
**/keys.json
*.wallet.json

# General JSON files that might contain sensitive data
scripts/*.json

# Wallet files
*.wallet
wallet.dat
wallet.json

# additional foundry artifacts
broadcast/

DApp_ideas.md
.history/
CLAUDE.md
.serena

# Foundry dependencies (installed via forge install --no-git)
contracts/lib/

# Foundry build artifacts
contracts/out/
contracts/out-permit2/
contracts/cache/
